# PointCloud Binning Configuration for Magpie

# Topic Configuration
input_topic: "/rslidar_points"
output_topic: "/processed_lidar"
queue_size: 1

# Binning Configuration
# Number of bins for discretizing the point cloud in azimuth (horizontal angle)
azimuth_bins: 480

# Number of bins for discretizing the point cloud in elevation (vertical angle)
elevation_bins: 48

# Output Configuration
# Target output dimensions after downsampling
target_rows: 16
target_cols: 20

# Range Configuration
# Minimum range in meters (points closer will be clamped to this value)
min_range: 0.4

# Maximum range in meters (points farther will be clamped to this value)
max_range: 10.0

# Filter Configuration
# Kernel size for filtering (must be odd)
filter_kernel_size: 7

# Filter type: "median" or "gaussian"
# - median: Better at preserving edges, removes salt-and-pepper noise
# - gaussian: Faster, smoother results
filter_type: "median"

# Processing Options
# Enable/disable filtering to reduce noise
enable_filter: true

# Enable/disable transpose and flip operations
enable_transpose_flip: true

# Invert depth values (converts distance to 1/distance)
invert_depth: true

# Enable verbose logging (prints processing time at INFO level)
verbose: true
