Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Axes1
        - /Axes1/TF1/Frames1
        - /Odometry1/Shape1
        - /Odometry1/Covariance1
        - /PlannerViz1
        - /PlannerViz1/BestPaths1/Namespaces1
        - /PlannerViz1/ShortestPaths1/Namespaces1
        - /PlannerViz1/RobotState1/Namespaces1
